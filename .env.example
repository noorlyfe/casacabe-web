# ── Stripe live (production — default) ──────────────────────────────────────
# STRIPE_MODE=live
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Live Payment Link (used on casacabe.com buy buttons)
# https://buy.stripe.com/00w00c04Ee2j4gI1L05ZC02

# ── Stripe test (preview / local only — never on production) ────────────────
# STRIPE_MODE=test
STRIPE_SECRET_KEY_TEST=sk_test_...
STRIPE_WEBHOOK_SECRET_TEST=whsec_...

# Test Payment Link — create in Stripe Dashboard with Test mode toggle ON
# (same product, $199). Paste the URL here for reference during E2E testing.
STRIPE_PAYMENT_LINK_TEST=https://buy.stripe.com/test_...

# ── Email (shared by live and test webhooks) ───────────────────────────────
RESEND_API_KEY=re_...
